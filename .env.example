# ─── Configuration Taskmout ──────────────────────────────────────────────
# Copier ce fichier en `.env.local` puis renseigner vos valeurs.
# Ne JAMAIS committer `.env.local` (déjà ignoré dans .gitignore).

# URL canonique du site (utilisée pour les balises Open Graph / Twitter)
NEXT_PUBLIC_SITE_URL=https://taskmout.fr

# Mot de passe d'accès à l'espace administrateur (/admin)
# IMPORTANT : changez cette valeur en production.
NEXT_PUBLIC_ADMIN_PASSWORD=taskmout

# (Optionnel) Secret serveur uniquement pour l’API commandes si vous ne souhaitez pas
# réutiliser le mot de passe public admin.
# ADMIN_SERVER_TOKEN=

# ─── Paiements SumUp (Hosted Checkout) ─────────────────────────────────────
# Clé API + code marchand depuis https://developer.sumup.com ou l’écran développeurs SumUp.
SUMUP_API_KEY=
SUMUP_MERCHANT_CODE=

# ─── Automatisation BC / BL (webhooks après paiement confirmé) ──────────────
# Reçoit un JSON structuré (bon de commande + bon de livraison). Deuxième URL optionnelle
# pour un deuxième système (ex. logistique / compta).
ORDER_WEBHOOK_URL=
ORDER_WEBHOOK_URL_SECONDARY=
ORDER_WEBHOOK_SECRET=

# ─── E-mails clients (transactionnels) ─────────────────────────────────────
# Transport SMTP (OVH, Brevo, Gmail workspace, etc.). Si absent, aucun mail n’est envoyé
# (paiement et commandes restent fonctionnels).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Adresse d’expéditeur (Doit être autorisée chez votre fournisseur SMTP.)
MAIL_FROM=noreply@votredomaine.fr
# Réponse humaine (optionnel)
MAIL_REPLY_TO=contact@taskmout.fr
